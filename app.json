{
  "expo": {
    "name": "SyncClipboard",
    "slug": "syncclipboard-mobile",
    "scheme": "syncclipboard",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jericx.syncclipboardmobile",
      "permissions": ["android.permission.REQUEST_INSTALL_PACKAGES"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/build/withNetworkSecurityConfig.js",
      "./plugins/build/withQuickSettingsTileManifest.js",
      "./plugins/build/withAndroidNativeCode.js",
      "./plugins/build/withAbiSplits.js",
      // "./plugins/build/withBackgroundSyncService.js",
      [
        "expo-sharing",
        {
          "android": {
            "enabled": true,
            "singleShareMimeTypes": ["*/*"]
          }
        }
      ]
    ]
  }
}
